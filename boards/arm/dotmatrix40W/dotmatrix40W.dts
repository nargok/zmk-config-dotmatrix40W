/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>


#include <dt-bindings/led/led.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/pwm/pwm.h>
#include <dt-bindings/pinctrl/nrf-pinctrl.h>

#include <physical_layouts.dtsi>

/ {
    model = "dotmatrix40W";
    compatible = "dotmatrix40W";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zmk,battery = &vbatt;
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
        zmk,backlight = &backlight;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)                 RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        diode-direction = "col2row";
        row-gpios = <&gpio0 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
            <&gpio0 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
            <&gpio0 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
            <&gpio0 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
        col-gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>, 
            <&gpio0 24 GPIO_ACTIVE_HIGH>,
            <&gpio1 0 GPIO_ACTIVE_HIGH>, 
            <&gpio0 22 GPIO_ACTIVE_HIGH>,
            <&gpio0 23 GPIO_ACTIVE_HIGH>, 
            <&gpio0 20 GPIO_ACTIVE_HIGH>,
            <&gpio0 21 GPIO_ACTIVE_HIGH>, 
            <&gpio0 19 GPIO_ACTIVE_HIGH>,
            <&gpio0 17 GPIO_ACTIVE_HIGH>, 
            <&gpio0 16 GPIO_ACTIVE_HIGH>,
            <&gpio0 13 GPIO_ACTIVE_HIGH>, 
            <&gpio0 14 GPIO_ACTIVE_HIGH>;
    };

    leds {
        compatible = "gpio-leds";
        status_led: led_0 {
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
            label = "Status LED";
        };
        blue_led: led_1 {
            gpios = <&gpio0 26 GPIO_ACTIVE_HIGH>;
        };
    };

    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 0>;
        output-ohms = <503000>;
        full-ohms = <(1000000 + 503000)>;
    };

    backlight: pwmleds {
        compatible = "pwm-leds";
        pwm_led_0: pwm_led_0 {
            pwms = <&pwm0 0 PWM_MSEC(10) PWM_POLARITY_NORMAL>;
        };
    };
    
    extra_power_2: extra_power_2 {
         compatible = "regulator-fixed";
         regulator-name = "extra_power_2";
         enable-gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
         regulator-boot-on;
         regulator-always-on;
    };

    encoder_left: encoder_left {
        compatible = "alps,ec11";
        label = "LEFT_ENCODER";
        a-gpios = <&gpio0 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <96>;
        status = "okay";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_left>;
        triggers-per-rotation = <24>;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys = <
            /* Row 0 */
            &key_physical_attrs 100 100 0 0 0 0 0
            &key_physical_attrs 100 100 100 0 0 0 0
            &key_physical_attrs 100 100 200 0 0 0 0
            &key_physical_attrs 100 100 300 0 0 0 0
            &key_physical_attrs 100 100 400 0 0 0 0
            &key_physical_attrs 100 100 500 0 0 0 0
            &key_physical_attrs 100 100 600 0 0 0 0
            &key_physical_attrs 100 100 700 0 0 0 0
            &key_physical_attrs 100 100 800 0 0 0 0
            &key_physical_attrs 100 100 900 0 0 0 0
            &key_physical_attrs 100 100 1000 0 0 0 0
            &key_physical_attrs 100 100 1100 0 0 0 0

            /* Row 1 */
            &key_physical_attrs 100 100 0 100 0 0 0
            &key_physical_attrs 100 100 100 100 0 0 0
            &key_physical_attrs 100 100 200 100 0 0 0
            &key_physical_attrs 100 100 300 100 0 0 0
            &key_physical_attrs 100 100 400 100 0 0 0
            &key_physical_attrs 100 100 500 100 0 0 0
            &key_physical_attrs 100 100 600 100 0 0 0
            &key_physical_attrs 100 100 700 100 0 0 0
            &key_physical_attrs 100 100 800 100 0 0 0
            &key_physical_attrs 100 100 900 100 0 0 0
            &key_physical_attrs 100 100 1000 100 0 0 0
            &key_physical_attrs 100 100 1100 100 0 0 0

            /* Row 2 */
            &key_physical_attrs 100 100 0 200 0 0 0
            &key_physical_attrs 100 100 100 200 0 0 0
            &key_physical_attrs 100 100 200 200 0 0 0
            &key_physical_attrs 100 100 300 200 0 0 0
            &key_physical_attrs 100 100 400 200 0 0 0
            &key_physical_attrs 100 100 500 200 0 0 0
            &key_physical_attrs 100 100 600 200 0 0 0
            &key_physical_attrs 100 100 700 200 0 0 0
            &key_physical_attrs 100 100 800 200 0 0 0
            &key_physical_attrs 100 100 900 200 0 0 0
            &key_physical_attrs 100 100 1000 200 0 0 0
            &key_physical_attrs 100 100 1100 200 0 0 0

            /* Row 3 (Bottom Row) */
            &key_physical_attrs 100 100 0 300 0 0 0      /* Fn1 */
            &key_physical_attrs 100 100 100 300 0 0 0    /* Option */
            &key_physical_attrs 100 100 200 300 0 0 0    /* Cmd */
            &key_physical_attrs 100 100 300 300 0 0 0    /* 英数 */
            &key_physical_attrs 150 100 400 300 0 0 0    /* Space (1.5U) */
            
            /* (x=550にエンコーダーがありますが、キースイッチではないためここではスキップします) */

            &key_physical_attrs 150 100 650 300 0 0 0    /* Enter (1.5U) */
            &key_physical_attrs 100 100 800 300 0 0 0    /* かな */
            &key_physical_attrs 100 100 900 300 0 0 0    /* = - */
            &key_physical_attrs 100 100 1000 300 0 0 0   /* ~ ^ */
            &key_physical_attrs 100 100 1100 300 0 0 0   /* Fn2 */
        >;
    };
};

&pinctrl {
    pwm0_default: pwm0_default {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 1, 9)>;
        };
    };
    pwm0_sleep: pwm0_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 1, 9)>;
            low-power-enable;
        };
    };
};

&pwm0 {
    status = "okay";
    pinctrl-0 = <&pwm0_default>;
    pinctrl-1 = <&pwm0_sleep>;
    pinctrl-names = "default", "sleep";
};


&adc {
    status = "okay";
};

&gpiote {
    status = "okay";
};

&gpio0 {
    status = "okay";
};

&gpio1 {
    status = "okay";
};


zephyr_udc0: &usbd {
    status = "okay";
};

&flash0 {
    /*
     * For more information, see:
     * http://docs.zephyrproject.org/latest/devices/dts/flash_partitions.html
     */
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            reg = <0x00000000 0x00001000>;
        };

        code_partition: partition@1000 {
            reg = <0x00001000 0x000d3000>;
        };

        /*
         * The flash starting at 0x000d4000 and ending at
         * 0x000f3fff is reserved for use by the application.
         */

        /*
         * Storage partition will be used by FCB/LittleFS/NVS
         * if enabled.
         */
        storage_partition: partition@d4000 {
            reg = <0x000d4000 0x00020000>;
        };

        boot_partition: partition@f4000 {
            reg = <0x000f4000 0x0000c000>;
        };
    };
};
